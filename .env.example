# ═══════════════════════════════════════════════════════════════════════════════
# tradex-ai Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ── LLM (Optional — enables AI multi-agent reasoning + prompt tuning) ────────
# Without this key, the system uses a built-in rule-based engine (still works)
ANTHROPIC_API_KEY=

# ── Data Providers (All optional — defaults work with zero keys) ─────────────
# OpenBB personal access token (optional, yfinance is used by default)
# OPENBB_TOKEN=

# WorldMonitor API (optional, yfinance news is used by default)
# WORLDMONITOR_API_BASE=https://api.worldmonitor.app
# WORLDMONITOR_API_KEY=

# ── Alerts (Optional) ───────────────────────────────────────────────────────
# Slack webhook URL for trade alerts (large losses, kill switch, errors)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://tradex:tradex@localhost:5432/tradex

# ── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
